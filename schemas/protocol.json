{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ornithemc.net/mc-versions/gen2/schemas/protocol.json",
  "$defs": {
    "version": {
      "description": "A version in the Omniarchive format",
      "type": "string",
      "pattern": "^((([abc]|inf?-|rd-|combat|3D Shareware v)?[0-9]+([.0-9]*|\\.RV))|[0-9]{2}w[0-9]{2}[a-z~])a?([_-][0-9Pa-z]+)*$"
    },
    "protocolVersion": {
      "type": "object",
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 0
        },
        "clients": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/version"
          }
        },
        "servers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/version"
          }
        }
      },
      "required": [
        "version",
        "clients",
        "servers"
      ],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "enum": [
        "classic",
        "modern",
        "netty",
        "netty-snapshot"
      ]
    },
    "versions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/protocolVersion"
      }
    }
  },
  "required": [
    "type",
    "versions"
  ],
  "additionalProperties": false
}